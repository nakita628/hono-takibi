{
  "name": "hono-takibi-monorepo",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "deps": "mkdir -p /tmp/pnpm-store && pnpm config set store-dir /tmp/pnpm-store &&rm -rf node_modules && rm -rf pnpm-lock.yaml && rm -rf ~/.pnpm-store && pnpm store prune && pnpm install --no-prefer-frozen-lockfile",
    "doc": "pnpm -F @docs/hono-takibi dev",
    "hono-takibi-deps": "pnpm -F hono-takibi deps",
    "check": "vp check --fix",
    "build": "pnpm -F hono-takibi build",
    "release": "pnpm -F hono-takibi release",
    "fixtures-typecheck": "pnpm -F @fixtures/generate typecheck",
    "fixtures-all": "pnpm -F @fixtures/generate all",
    "tsgo": "pnpm -F @fixtures/generate typecheck",
    "test": "vp test",
    "coverage": "vp test --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "vite-plus": "^0.1.15"
  },
  "packageManager": "pnpm@10.32.1"
}
