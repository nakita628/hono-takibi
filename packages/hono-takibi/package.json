{
  "name": "hono-takibi",
  "version": "0.9.9998",
  "description": "Hono Takibi is a code generator from OpenAPI to @hono/zod-openapi",
  "keywords": [
    "hono",
    "openapi"
  ],
  "homepage": "https://github.com/nakita628/hono-takibi",
  "bugs": {
    "url": "https://github.com/nakita628/hono-takibi/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nakita628/hono-takibi.git"
  },
  "bin": {
    "hono-takibi": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./vite-plugin": {
      "types": "./dist/vite-plugin/index.d.ts",
      "import": "./dist/vite-plugin/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./zod-openapi-hono": {
      "types": "./dist/generator/zod-openapi-hono/openapi/index.d.ts",
      "import": "./dist/generator/zod-openapi-hono/openapi/index.js"
    },
    "./rpc": {
      "types": "./dist/core/rpc/index.d.ts",
      "import": "./dist/core/rpc/index.js"
    },
    "./hooks": {
      "types": "./dist/core/hooks/index.d.ts",
      "import": "./dist/core/hooks/index.js"
    },
    "./type": {
      "types": "./dist/core/type/index.d.ts",
      "import": "./dist/core/type/index.js"
    },
    "./docs": {
      "types": "./dist/core/docs/index.d.ts",
      "import": "./dist/core/docs/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@typespec/compiler": "^1.13.0",
    "@typespec/openapi3": "^1.13.0",
    "oxfmt": "^0.54.0",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typespec/http": "^1.13.0",
    "@typespec/rest": "^0.83.0",
    "@typespec/versioning": "^0.83.0",
    "tsdown": "0.22.2"
  }
}
